{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist-seed"
  },
  "include": ["prisma/**/*.ts", "src/generated/**/*.ts"],
  "exclude": ["node_modules"]
}
